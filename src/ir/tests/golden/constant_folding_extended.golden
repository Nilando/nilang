OPT=true

%%%%

a = 7 & 3;     // BitAnd  -> 3
b = 5 | 2;     // BitOr   -> 7
c = 6 ^ 3;     // BitXor  -> 5
d = 10 > 3;    // Gt      -> true
e = 4 >= 9;    // Gte     -> false
f = 2 <= 2;    // Lte     -> true
g = 1.5 < 2;   // Lt (mixed int/float) -> true
h = 3.0 > 2.5; // Gt (float)  -> true

print(a);
print(b);
print(c);
print(d);
print(e);
print(f);
print(g);
print(h);

%%%%

